# --- Conversation Model ---
# Gemini Flash is the default (free tier, kid-safe filters built in)
# Get your key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Anthropic API key (used as fallback if Gemini is not configured)
# Get your key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Get your API key from https://console.cloud.google.com/
YOUTUBE_API_KEY=your-youtube-data-api-key-here

# Google OAuth 2.0 (for YouTube sign-in)
# Create at https://console.cloud.google.com/apis/credentials
# Set redirect URI to http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Session secret (any random string)
SESSION_SECRET=change-me-to-something-random

# Learner profile ID (default: 'default')
# Use a unique ID if you have multiple kids
LEARNER_PROFILE_ID=default

# Server port
PORT=3000

# Parental PIN (4-6 digits)
PARENT_PIN=1234
